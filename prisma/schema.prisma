generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Models ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  dashboards        UserDashboard[]
  stack             UserStack[]
  notificationPrefs UserNotificationPref[]
  alertStates       UserAlertState[]
  pushSubscriptions PushSubscription[]
  notificationLogs  NotificationLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Alert ──────────────────────────────────────────────────────

model Alert {
  id          String    @id @default(cuid())
  externalId  String
  source      String
  category    String    // cloud, security, isp, devops
  severity    String    // critical, major, minor, info
  title       String
  description String?
  url         String?
  region      String?
  timestamp   DateTime
  status      String    // active, resolved, investigating, monitoring
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  alertStates      UserAlertState[]
  notificationLogs NotificationLog[]

  @@unique([source, externalId])
}

// ─── User Dashboard & Preferences ──────────────────────────────

model UserDashboard {
  id             String  @id @default(cuid())
  userId         String
  name           String
  layout         String  // JSON stored as text (SQLite)
  pinnedServices String  // JSON stored as text
  filters        String  // JSON stored as text
  isDefault      Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStack {
  id          String  @id @default(cuid())
  userId      String
  serviceName String
  provider    String
  region      String?
  notes       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserNotificationPref {
  id             String  @id @default(cuid())
  userId         String
  channel        String  // email, slack, teams, push
  enabled        Boolean @default(true)
  config         String  // JSON stored as text (webhook URL, etc.)
  severityFilter String  // JSON stored as text
  sourceFilter   String  // JSON stored as text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAlertState {
  id           String    @id @default(cuid())
  userId       String
  alertId      String
  state        String    // acknowledged, snoozed, dismissed
  snoozedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([userId, alertId])
}

// ─── Push Notifications ─────────────────────────────────────────

model PushSubscription {
  id       String   @id @default(cuid())
  userId   String
  endpoint String
  p256dh   String
  auth     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Audit Logs ─────────────────────────────────────────────────

model NotificationLog {
  id      String   @id @default(cuid())
  userId  String
  channel String
  alertId String
  sentAt  DateTime @default(now())
  success Boolean
  error   String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
}

model PollLog {
  id          String    @id @default(cuid())
  provider    String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  alertsFound Int       @default(0)
  newAlerts   Int       @default(0)
  error       String?
}

// ─── Dependency Map ─────────────────────────────────────────────

model DependencyMap {
  id               String   @id @default(cuid())
  provider         String
  dependentService String
  confidence       String   // confirmed, likely, possible
  region           String?
  source           String
  updatedAt        DateTime @updatedAt
}
