# Database
# Local dev:
DATABASE_URL="file:./dev.db"
# Docker: set via docker-compose.yml (file:/app/data/monitor.db)

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Local dev:
AUTH_URL="http://localhost:3000"
# Production:
# AUTH_URL="https://monitor.ducktyped.com"

# OAuth Providers
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_MICROSOFT_ID=""
AUTH_MICROSOFT_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="alerts@monitor.ducktyped.com"

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@ducktyped.com"

# Slack Webhook (optional)
SLACK_WEBHOOK_URL=""

# Teams Webhook (optional)
TEAMS_WEBHOOK_URL=""

# App
# Local dev:
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production:
# NEXT_PUBLIC_APP_URL="https://monitor.ducktyped.com"
